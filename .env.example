# AgentTest — environment variables
#
# Copy this file to `.env` (gitignored) and fill in real values.
# A placeholder is fine for ANTHROPIC_API_KEY at startup; the FastAPI app
# will boot without a real key, but actual generation calls will fail.

# Required for LLM generation (Sonnet for test synthesis, Haiku for analyzer/judge).
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional. Only needed if a future role wires an OpenAI provider in
# `engine/configs/agents.yaml`. The current default config does not require it.
# OPENAI_API_KEY=

# Optional. Override paths to Java toolchain when not on PATH.
# JAVA_HOME=/path/to/jdk-17
# MAVEN_HOME=/path/to/maven
